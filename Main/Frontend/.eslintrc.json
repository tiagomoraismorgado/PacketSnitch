{
  "env": {
    "node": true,
    "browser": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:node/recommended",
    "plugin:electron/recommended"
  ],
  "plugins": ["node", "electron"],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "semi": ["error", "always"],
    "quotes": ["warn", "single"],
    "no-console": "off",
    "no-unused-vars": ["warn"],
    "no-undef": "off",
    "no-control-regex": "off",
    "node/no-unpublished-require": "off",
    "node/no-missing-require": "off",
    "no-prototype-builtins": "warn",
    "node/no-unsupported-features/es-syntax": "off"
  }
}
