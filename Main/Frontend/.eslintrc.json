{
  "env": {
    "node": true,
    "browser": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:node/recommended",
    "plugin:electron/recommended"
  ],
  "plugins": [
    "node",
    "electron"
  ],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "semi": ["error", "always"],
    "quotes": ["error", "single"],
    "no-console": "off",
    "node/no-unpublished-require": "off"
  }
}
